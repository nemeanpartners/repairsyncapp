{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"],
    "noEmit": true
  },
  "include": ["server.ts", "server"]
}
