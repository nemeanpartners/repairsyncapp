{
  "name": "repairsync-sms",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "lint": "tsc -b tsconfig.app.json tsconfig.server.json",
    "postinstall": "patch-package",
    "mobile:check": "node scripts/mobile-check.mjs",
    "billing:grandfather": "node scripts/grandfather-existing-users.mjs",
    "ios:spm:fix": "node scripts/fix-ios-spm.mjs",
    "cap:add": "cap add android && cap add ios",
    "cap:sync": "cap sync && npm run ios:spm:fix",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "twa:init": "bash scripts/twa-init.sh",
    "twa:build": "bash scripts/twa-build.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@capacitor-firebase/app": "8.2.0",
    "@capacitor-firebase/messaging": "8.2.0",
    "@capacitor/core": "^8.3.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.26",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "emoji-picker-react": "^4.18.0",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "firebase": "12.13.0",
    "firebase-admin": "^13.8.0",
    "fuse.js": "^7.3.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lodash": "^4.18.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.1",
    "react-intersection-observer": "^10.0.3",
    "react-mentions": "^4.4.10",
    "react-router-dom": "^7.14.1",
    "react-virtualized-auto-sizer": "^2.0.3",
    "recharts": "^3.9.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "stripe": "^18.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.2",
    "uuid": "^14.0.0",
    "vite": "^6.2.0",
    "xero-node": "^15.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@bubblewrap/cli": "^1.24.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.14.0",
    "@types/react-mentions": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "patch-package": "^8.0.1",
    "puppeteer": "^24.42.0"
  },
  "overrides": {
    "node-domexception": "file:./scripts/local-domexception"
  }
}
