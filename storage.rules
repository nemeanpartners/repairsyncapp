rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isGuest() { return request.auth != null && request.auth.token.firebase.sign_in_provider == 'anonymous'; }
    
    match /attachments/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId && !isGuest();
    }
    match /receipts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && !isGuest();
    }
  }
}

