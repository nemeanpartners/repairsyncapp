# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# RepairShopr API
REPAIRSHOPR_SUBDOMAIN=
REPAIRSHOPR_API_KEY=

# Mobile Message API
MOBILE_MESSAGE_USERNAME=
MOBILE_MESSAGE_PASSWORD=
MOBILE_MESSAGE_SENDER_ID=

# Zoho Mail API Configuration
# Get these from https://api-console.zoho.com.au
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Use 'au' for Australia, 'us' for US
ZOHO_REGION=au
ZOHO_REDIRECT_URI=https://ais-pre-lb5osczayhuesptlbuidis-781642394561.asia-southeast1.run.app/api/auth/zoho/callback

# Xero API Configuration
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://repairsync-sms.run.app/api/auth/xero/callback

# Maxotel API Configuration
MAXOTEL_API_KEY=

# Bot API Configuration
BOT_API_KEY=repairsync_bot_secret_2024

# Messaging Providers (e.g., Twilio, MessageBird, Google RBM)
# Leave blank for local UI simulation, or fill in to enable production RCS
RCS_PROVIDER_API_KEY=
RCS_PROVIDER_WEBHOOK_SECRET=
SMS_PROVIDER_API_KEY=

# Web/native integration
# For embedded Capacitor builds, point the web app at your backend origin.
VITE_API_BASE_URL=
# For live-reload Capacitor wrapper sessions, point the wrapper at the running web server.
CAP_SERVER_URL=
CAP_SERVER_CLEAR_TEXT=false

# Stripe billing
APP_BASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
SUBSCRIPTION_GRANDFATHER_CUTOFF=2026-06-12T00:00:00.000Z
VITE_SUBSCRIPTION_GRANDFATHER_CUTOFF=2026-06-12T00:00:00.000Z
